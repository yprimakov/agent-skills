{
  // ============================================================
  // yuryprimakov.com — Design Token Architecture
  // Extracted: 2026-03-17
  // Framework: Tailwind CSS v3.4.13 + shadcn/ui default theme
  // ============================================================

  "meta": {
    "site": "yuryprimakov.com",
    "framework": "Next.js 13+ App Router",
    "cssFramework": "Tailwind CSS v3.4.13",
    "componentLibrary": "shadcn/ui (default theme)",
    "themeMode": "light/dark (localStorage + system preference)",
    "fontStrategy": "system-ui stack (no web fonts)"
  },

  "colors": {
    // All values derived from HSL CSS custom properties
    // Format: { light: hex, dark: hex, hsl_light: string, hsl_dark: string }

    "background": {
      "light": "#ffffff",
      "dark": "#020817",
      "hsl_light": "0 0% 100%",
      "hsl_dark": "222.2 84% 4.9%",
      "tailwind_dark": "slate-950",
      "notes": "Page background. Dark mode is very deep navy, not pure black."
    },
    "foreground": {
      "light": "#020817",
      "dark": "#f8fafc",
      "hsl_light": "222.2 84% 4.9%",
      "hsl_dark": "210 40% 98%",
      "tailwind_light": "slate-950",
      "tailwind_dark": "slate-50",
      "notes": "Primary body text color."
    },
    "primary": {
      "light": "#0f172a",
      "dark": "#f8fafc",
      "hsl_light": "222.2 47.4% 11.2%",
      "hsl_dark": "210 40% 98%",
      "tailwind_light": "slate-900",
      "tailwind_dark": "slate-50",
      "notes": "Used for primary buttons, key interactive elements."
    },
    "primaryForeground": {
      "light": "#f8fafc",
      "dark": "#0f172a",
      "hsl_light": "210 40% 98%",
      "hsl_dark": "222.2 47.4% 11.2%",
      "notes": "Text color on primary-colored surfaces."
    },
    "secondary": {
      "light": "#f1f5f9",
      "dark": "#1e293b",
      "hsl_light": "210 40% 96.1%",
      "hsl_dark": "217.2 32.6% 17.5%",
      "tailwind_light": "slate-100",
      "tailwind_dark": "slate-800",
      "notes": "Secondary button backgrounds, subdued surfaces."
    },
    "muted": {
      "light": "#f1f5f9",
      "dark": "#1e293b",
      "hsl_light": "210 40% 96.1%",
      "hsl_dark": "217.2 32.6% 17.5%",
      "tailwind_light": "slate-100",
      "tailwind_dark": "slate-800",
      "notes": "Same as secondary. Used for muted/disabled area backgrounds."
    },
    "mutedForeground": {
      "light": "#64748b",
      "dark": "#94a3b8",
      "hsl_light": "215.4 16.3% 46.9%",
      "hsl_dark": "215 20.2% 65.1%",
      "tailwind_light": "slate-500",
      "tailwind_dark": "slate-400",
      "notes": "Secondary/caption text, placeholders, metadata."
    },
    "accent": {
      "light": "#f1f5f9",
      "dark": "#1e293b",
      "hsl_light": "210 40% 96.1%",
      "hsl_dark": "217.2 32.6% 17.5%",
      "notes": "Hover states on ghost/icon buttons."
    },
    "border": {
      "light": "#e2e8f0",
      "dark": "#1e293b",
      "hsl_light": "214.3 31.8% 91.4%",
      "hsl_dark": "217.2 32.6% 17.5%",
      "tailwind_light": "slate-200",
      "tailwind_dark": "slate-800",
      "notes": "Card borders, dividers, input borders."
    },
    "ring": {
      "light": "#020817",
      "dark": "#cbd5e1",
      "hsl_light": "222.2 84% 4.9%",
      "hsl_dark": "212.7 26.8% 83.9%",
      "tailwind_light": "slate-950",
      "tailwind_dark": "slate-300",
      "notes": "Focus ring / outline color."
    },
    "destructive": {
      "light": "#ef4444",
      "dark": "#7f1d1d", // UNVERIFIED — computed from hsl(0, 62.8%, 30.6%)
      "hsl_light": "0 84.2% 60.2%",
      "hsl_dark": "0 62.8% 30.6%",
      "tailwind_light": "red-500",
      "notes": "Error states, destructive actions."
    },

    // Gradient accent palette
    // These are the gradient color stops present in the stylesheet.
    // The site uses colorful gradients for accent elements (skill badges, tags, decorations).
    "gradients": {
      "coolTech": {
        "from": "#3b82f6",   // blue-500
        "via": "#06b6d4",    // cyan-500
        "to": "#14b8a6",     // teal-500
        "notes": "Technical/engineering feel"
      },
      "skyIndigo": {
        "from": "#38bdf8",   // sky-400
        "via": "#3b82f6",    // blue-500
        "to": "#4f46e5",     // indigo-600
        "notes": "Crisp blue spectrum"
      },
      "creative": {
        "from": "#a855f7",   // purple-500
        "via": "#ec4899",    // pink-500
        "to": "#ef4444",     // red-500
        "notes": "Bold creative / AI feel"
      },
      "purplePink": {
        "from": "#c084fc",   // purple-400
        "via": "#ec4899",    // pink-500
        "to": "#f472b6",     // pink-400
        "notes": "Softer creative"
      },
      "warm": {
        "from": "#fb923c",   // orange-400
        "via": "#facc15",    // yellow-400
        "to": "#a3e635",     // lime-400
        "notes": "Warm energy / interests section"
      },
      "greenTeal": {
        "from": "#22c55e",   // green-500
        "via": "#10b981",    // emerald-500
        "to": "#0d9488",     // teal-600
        "notes": "Nature / growth"
      }
    },

    // Theme overlays used in theme toggle script
    "overlays": {
      "darkOverlay": "rgba(0,0,0,0.3)",
      "lightOverlay": "rgba(255,255,255,0.3)"
    }
  },

  "typography": {
    "fontFamilies": {
      "sans": "system-ui, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif, 'Apple Color Emoji', 'Segoe UI Emoji'",
      "notes": "No custom web fonts. Renders as Segoe UI (Windows), SF Pro (macOS), Roboto (Android)."
    },

    "fontSizes": {
      "xs":   { "size": "0.75rem",   "lineHeight": "1rem",    "px": "12px" },
      "sm":   { "size": "0.875rem",  "lineHeight": "1.25rem", "px": "14px" },
      "base": { "size": "1rem",      "lineHeight": "1.5rem",  "px": "16px" },
      "lg":   { "size": "1.125rem",  "lineHeight": "1.75rem", "px": "18px" },
      "xl":   { "size": "1.25rem",   "lineHeight": "1.75rem", "px": "20px" },
      "2xl":  { "size": "1.5rem",    "lineHeight": "2rem",    "px": "24px" },
      "3xl":  { "size": "1.875rem",  "lineHeight": "2.25rem", "px": "30px" },
      "4xl":  { "size": "2.25rem",   "lineHeight": "2.5rem",  "px": "36px" },
      "6xl":  { "size": "3.75rem",   "lineHeight": "1",       "px": "60px" }
    },

    "fontWeights": {
      "light":    300,
      "normal":   400,
      "medium":   500,
      "semibold": 600,
      "bold":     700,
      "black":    900
    },

    "letterSpacing": {
      "tight":  "-0.05em",
      "normal": "0em",
      "wide":   "0.025em",
      "wider":  "0.05em",
      "widest": "0.1em"
    }
  },

  "spacing": {
    // Tailwind default 4px base unit
    "unit": "0.25rem",
    "scale": {
      "0.5": "0.125rem",  // 2px
      "1":   "0.25rem",   // 4px
      "1.5": "0.375rem",  // 6px
      "2":   "0.5rem",    // 8px
      "3":   "0.75rem",   // 12px
      "4":   "1rem",      // 16px
      "5":   "1.25rem",   // 20px
      "6":   "1.5rem",    // 24px
      "8":   "2rem",      // 32px
      "10":  "2.5rem",    // 40px
      "12":  "3rem",      // 48px
      "16":  "4rem",      // 64px
      "20":  "5rem",      // 80px
      "24":  "6rem"       // 96px
    }
  },

  "borders": {
    "radius": {
      "base":  "0.5rem",  // --radius CSS var (8px)
      "sm":    "0.25rem", // calc(var(--radius) - 4px)
      "md":    "0.375rem", // calc(var(--radius) - 2px)
      "lg":    "0.5rem",  // var(--radius)
      "xl":    "0.75rem",
      "2xl":   "1rem",
      "3xl":   "1.5rem",
      "full":  "9999px"
    },
    "widths": {
      "DEFAULT": "1px",
      "0": "0px",
      "2": "2px",
      "4": "4px"
    }
  },

  "shadows": {
    "sm":     "0 1px 2px 0 rgba(0,0,0,0.05)",
    "DEFAULT": "0 1px 3px 0 rgba(0,0,0,0.1), 0 1px 2px -1px rgba(0,0,0,0.1)",
    "md":     "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1)",
    "lg":     "0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1)",
    "xl":     "0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1)",
    "2xl":    "0 25px 50px -12px rgba(0,0,0,0.25)",
    "inner":  "inset 0 2px 4px 0 rgba(0,0,0,0.05)"
  },

  "motion": {
    "durations": {
      "0":    "0s",
      "75":   "0.075s",
      "100":  "0.1s",
      "150":  "0.15s",
      "200":  "0.2s",   // Standard hover transition
      "300":  "0.3s",   // Page-level transitions
      "500":  "0.5s",
      "700":  "0.7s",
      "1000": "1s"
    },
    "easings": {
      "linear":    "linear",
      "in":        "cubic-bezier(0.4, 0, 1, 1)",
      "out":       "cubic-bezier(0, 0, 0.2, 1)",
      "in-out":    "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "animations": {
      "spotlightGlow": {
        "type": "JavaScript-driven mouse-follow effect",
        "implementation": "React hook tracks window mousemove → getBoundingClientRect per card → sets --mouse-x / --mouse-y CSS vars → pseudo-element divs translate to cursor position",
        "throttle": "requestAnimationFrame (~100ms debounce)",
        "layers": {
          "layer1": {
            "size": "320×320px (w-80 h-80)",
            "offset": "-left-40 -top-40",
            "color_light": "#f1f5f9",  // slate-100
            "color_dark": "#f1f5f9",   // slate-100
            "blur": "blur-[100px]",
            "opacity": "opacity-20",
            "zIndex": "z-10"
          },
          "layer2": {
            "size": "384×384px (w-96 h-96)",
            "offset": "-left-48 -top-48",
            "color_light": "#ede9fe",  // violet-100
            "color_dark": "#8b5cf6",   // violet-500 — the signature purple glow
            "blur": "blur-[100px]",
            "opacity_light": "opacity-20",
            "opacity_dark": "dark:group-hover:opacity-10",
            "zIndex": "z-30"
          }
        },
        "containerClasses": "relative rounded-3xl p-px group backdrop-blur-md",
        "notes": "Effect is always active (not hover-gated). Dark mode is more dramatic due to saturated violet-500 vs near-black bg."
      },
      "scroll": {
        "keyframes": "0% { transform: translateX(0) } 100% { transform: translateX(-100%) }",
        "duration": "20s",
        "timing": "linear",
        "iteration": "infinite",
        "notes": "Horizontal skills marquee — scrolls duplicated content for seamless loop"
      },
      "bounce": {
        "keyframes": "0%,100% { transform: translateY(-25%); timing: cubic-bezier(0.8,0,1,1) } 50% { transform: none; timing: cubic-bezier(0,0,0.2,1) }",
        "notes": "Standard Tailwind bounce"
      },
      "pulse": {
        "keyframes": "50% { opacity: 0.5 }",
        "notes": "Standard Tailwind pulse"
      },
      "spin": {
        "keyframes": "to { transform: rotate(360deg) }",
        "notes": "Standard Tailwind spin"
      }
    }
  },

  "effects": {
    "backdropBlur": {
      "sm": "blur(4px)",
      "md": "blur(12px)",
      "xl": "blur(24px)",
      "notes": "Used for frosted glass — likely nav bar background on scroll"
    }
  },

  "breakpoints": {
    "xs":  "475px",
    "sm":  "640px",
    "md":  "768px",
    "lg":  "1024px",
    "xl":  "1280px",
    "2xl": "1536px"
  },

  "components": {
    // UNVERIFIED — inferred from content structure and common shadcn/ui patterns
    // Actual Tailwind class names could not be extracted due to RSC streaming architecture

    "nav": {
      "position": "sticky top-0",
      "background": "bg-background/80 backdrop-blur-md", // UNVERIFIED
      "border": "border-b border-border",                // UNVERIFIED
      "items": ["About", "Skills", "Portfolio", "Login"],
      "notes": "Likely frosted glass on scroll given backdrop-blur utilities present"
    },
    "hero": {
      "layout": "flex flex-col items-center text-center", // UNVERIFIED
      "profileImage": {
        "size": "256×256px",
        "shape": "rounded-full",
        "src": "/_next/static/media/profile-yury.14257e95.png"
      },
      "primaryCTA": "Resume (Google Drive link)",
      "socials": ["GitHub", "CodePen", "LinkedIn", "Contact"]
    },
    "skillsMarquee": {
      "animation": "animate-scroll",
      "duration": "20s",
      "overflow": "overflow-hidden",
      "notes": "Horizontal scrolling strip of skill badges, likely with gradient fills"
    },
    "experienceCard": {
      "border": "border border-border rounded-lg", // UNVERIFIED
      "shadow": "shadow-md",                        // UNVERIFIED
      "count": 5,
      "dateRange": "2003–2025"
    },
    "themeToggle": {
      "storageKey": "theme",
      "values": ["light", "dark", "system"],
      "systemQuery": "(prefers-color-scheme: dark)",
      "appliedTo": "html element .dark class"
    }
  }
}
